{"timestamp": "2026-04-30T14:26:15.402593+00:00", "session_id": "0a7ce931-beea-44c8-a197-fdf882ff5fd9", "cwd": "/Users/toby/Documents/Projects/CodeIsland/sync-daemon", "tool": "Bash", "input": {"command": "node -e \"\nconst crypto = require('crypto');\nconst secret = '3a662d86367b9d6dcf0d8d6ca4b63748a37017a13a8fa5334817bdb952eef610';\nconst deviceId = 'bdd06b490f2d4c96842c498c5d321349';\nconst header = Buffer.from(JSON.stringify({alg:'HS256',typ:'JWT'})).toString('base64url');\nconst payload = Buffer.from(JSON.stringify({deviceId, iat: Math.floor(Date.now()/1000), exp: Math.floor(Date.now()/1000)+3600})).toString('base64url');\nconst sig = crypto.createHmac('sha256', secret).update(header+'.'+payload).digest('base64url');\nconsole.log(header+'.'+payload+'.'+sig);\n\" 2>&1", "description": "Generate JWT using Node.js crypto"}, "result": "PreToolUse"}
{"timestamp": "2026-04-30T14:26:28.689925+00:00", "session_id": "0a7ce931-beea-44c8-a197-fdf882ff5fd9", "cwd": "/Users/toby/Documents/Projects/CodeIsland/sync-daemon", "tool": "Bash", "input": {"command": "TOKEN=\"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJkZXZpY2VJZCI6ImJkZDA2YjQ5MGYyZDRjOTY4NDJjNDk4YzVkMzIxMzQ5IiwiaWF0IjoxNzc3NTU5MTc5LCJleHAiOjE3Nzc1NjI3Nzl9.i_QkjJ3BBfVDFIq8jfoeXpEs04SUcxr8pOr1d-sV96g\"\ncurl -s \"https://mio-server-production.up.railway.app/v1/sessions\" \\\n  -H \"Authorization: Bearer $TOKEN\" 2>&1 | python3 -c \"\nimport sys,json\nd=json.load(sys.stdin)\nsessions = d.get('sessions', d) if isinstance(d, dict) else d\nprint(f'Sessions: {len(sessions)}')\nfor s in sessions[:10]:\n    print(f'  {s[\\\"id\\\"]} status={s.get(\\\"status\\\",\\\"?\\\")} messages={s.get(\\\"messageCount\\\",s.get(\\\"message_count\\\",\\\"?\\\"))}')\n\" 2>&1", "description": "Query server sessions with JWT auth"}, "result": "PreToolUse"}
